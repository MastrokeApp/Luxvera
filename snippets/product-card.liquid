{% doc %}
  Product card

  Renders a product's image, title, price, and add-to-cart button. Products with
  more than one variant show "Select Size" and open the parent section's size
  picker (via the data-* attributes below); single-variant products add directly.

  @param {product} product - product object
  @param {string} [card_context] - 'collection' | 'product-tabs' | 'dress-looks' (adds a modifier class)
  @param {string} [atc_label] - button label for single-variant products (default: 'Add To Cart')
  @param {string} [image_ratio] - image aspect-ratio modifier (default: 'portrait')

  @example
  {% render 'product-card', product: product, card_context: 'collection' %}
{% enddoc %}

{%- liquid
  assign card_context = card_context | default: 'default'
  assign atc_label = atc_label | default: 'Add To Cart'
  assign image_ratio = image_ratio | default: 'portrait'

  assign fv = product.selected_or_first_available_variant | default: product.variants.first

  assign multi = false
  if product.variants.size > 1
    assign multi = true
  endif

  assign variants_data = ''
  for v in product.variants
    assign vdata = v.id | append: '||' | append: v.title | append: '||' | append: v.available
    unless forloop.first
      assign variants_data = variants_data | append: '::'
    endunless
    assign variants_data = variants_data | append: vdata
  endfor

  assign wrapper_class = 'product-card'
  case card_context
    when 'dress-looks'
      assign wrapper_class = 'product-card product-card--dress-looks'
    when 'product-tabs'
      assign wrapper_class = 'product-card product-card--product-tabs'
    when 'collection'
      assign wrapper_class = 'product-card product-card--collection'
  endcase

  assign image_wrap_class = 'product-img-wrap product-img-wrap--' | append: image_ratio
-%}

<div class="{{ wrapper_class }}">
  <a class="{{ image_wrap_class }}" href="{{ product.url }}" aria-label="{{ product.title | escape }}">
    {%- if product.featured_image != blank -%}
      <img
        src="{{ product.featured_image | image_url: width: 700 }}"
        alt="{{ product.title | escape }}"
        width="{{ product.featured_image.width }}"
        height="{{ product.featured_image.height }}"
        loading="lazy"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </a>

  <div class="product-info">
    <a class="product-name" href="{{ product.url }}">{{ product.title | escape }}</a>

    <div class="price-color-row">
      <span class="price-new">{{ product.price | money }}</span>
      {%- if product.compare_at_price > product.price -%}
        <span class="price-old">{{ product.compare_at_price | money }}</span>
      {%- endif -%}
    </div>

    <button
      class="add-to-cart product-card__atc"
      data-variant-id="{{ fv.id }}"
      data-product-url="{{ product.url }}"
      data-product-title="{{ product.title | escape }}"
      data-multi="{{ multi }}"
      data-variants="{{ variants_data | escape }}"
      data-label-adding="{{ 'products.adding' | t }}"
      data-label-added="{{ 'products.added' | t }}"
      {%- unless product.available %} disabled aria-disabled="true"{% endunless -%}
    >
      {%- if product.available -%}
        {%- if multi -%}
          {{ 'products.select_size' | t }}
        {%- else -%}
          {{ atc_label }}
        {%- endif -%}
      {%- else -%}
        {{ 'products.sold_out' | t }}
      {%- endif -%}

      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
        <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
        <line x1="3" y1="6" x2="21" y2="6"/>
        <path d="M16 10a4 4 0 01-8 0"/>
      </svg>
    </button>
  </div>
</div>