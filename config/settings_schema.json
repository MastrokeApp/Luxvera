[
  {
    "name": "theme_info",
    "theme_name": "Luxvera",
    "theme_version": "1.0.0",
    "theme_author": "Luxvera Studio",
    "theme_documentation_url": "https://luxvera.com/docs",
    "theme_support_url": "https://luxvera.com/support"
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:labels.background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:labels.background_gradient",
            "info": "t:labels.optional_gradient_background"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:labels.text",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button",
            "label": "t:labels.primary_button_background",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "t:labels.primary_button_text",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "t:labels.secondary_button_text",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "t:labels.shadow",
            "default": "#121212"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "secondary_button_label",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label"
        }
      }
    ]
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.heading_font"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "t:labels.heading_font",
        "default": "playfair_display_n4"
      },
      {
        "type": "range",
        "id": "font_heading_scale",
        "label": "t:labels.heading_scale",
        "min": 80,
        "max": 150,
        "step": 5,
        "unit": "%",
        "default": 100
      },
      {
        "type": "header",
        "content": "t:labels.body_font"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "t:labels.body_font",
        "default": "josefin_sans_n4"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "label": "t:labels.base_font_size",
        "min": 12,
        "max": 18,
        "step": 1,
        "unit": "px",
        "default": 15
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.container"
      },
      {
        "type": "range",
        "id": "container_max",
        "label": "t:labels.max_content_width",
        "min": 960,
        "max": 1600,
        "step": 40,
        "unit": "px",
        "default": 1280
      },
      {
        "type": "range",
        "id": "grid_gutter",
        "label": "t:labels.grid_gutter",
        "min": 8,
        "max": 48,
        "step": 4,
        "unit": "px",
        "default": 24
      },
      {
        "type": "header",
        "content": "t:labels.logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "label": "t:labels.logo_max_width",
        "min": 60,
        "max": 300,
        "step": 10,
        "unit": "px",
        "default": 140
      },
      {
        "type": "header",
        "content": "t:labels.buttons"
      },
      {
        "type": "select",
        "id": "button_style",
        "label": "t:labels.button_style",
        "options": [
          {
            "value": "sharp",
            "label": "t:options.button_style.sharp"
          },
          {
            "value": "soft",
            "label": "t:options.button_style.soft"
          },
          {
            "value": "rounded",
            "label": "t:options.button_style.rounded"
          }
        ],
        "default": "sharp"
      },
      {
        "type": "header",
        "content": "t:labels.animations"
      },
      {
        "type": "checkbox",
        "id": "enable_animations",
        "label": "t:labels.enable_scroll_animations",
        "default": true
      }
    ]
  },
  {
    "name": "t:general.social_media",
    "settings": [
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "t:labels.instagram_url"
      },
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "t:labels.facebook_url"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "t:labels.pinterest_url"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "t:labels.tiktok_url"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "t:labels.youtube_url"
      }
    ]
  },
  {
    "name": "t:general.favicon_and_seo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "t:labels.logo_overrides_text"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.recommended_32x32px_ico_or_png_file"
      }
    ]
  },
  {
    "name": "t:general.cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "t:labels.cart_type",
        "options": [
          {
            "value": "page",
            "label": "t:options.cart_type.page"
          },
          {
            "value": "drawer",
            "label": "t:options.cart_type.drawer"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_notes",
        "label": "t:labels.enable_order_notes",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "cart_gift_notes",
        "label": "t:labels.enable_gift_message",
        "default": false
      },
      {
        "type": "header",
        "content": "t:labels.cart_text_settings"
      },
      {
        "type": "text",
        "id": "cart_summary_title",
        "label": "t:labels.cart_summary_title",
        "default": "Order Summary"
      },
      {
        "type": "text",
        "id": "subtotal_label",
        "label": "t:labels.subtotal_label",
        "default": "Subtotal"
      },
      {
        "type": "text",
        "id": "savings_label",
        "label": "t:labels.savings_label",
        "default": "Savings"
      },
      {
        "type": "checkbox",
        "id": "enable_shipping_link",
        "label": "t:labels.enable_shipping_link",
        "default": true
      },
      {
        "type": "text",
        "id": "shipping_label",
        "label": "t:labels.shipping_label",
        "default": "Shipping"
      },
      {
        "type": "text",
        "id": "shipping_text",
        "label": "t:labels.shipping_text",
        "default": "Calculated at checkout"
      },
      {
        "type": "url",
        "id": "shipping_url",
        "label": "t:labels.shipping_url"
      },
      {
        "type": "text",
        "id": "totalprice_label",
        "label": "t:labels.total_label",
        "default": "Total"
      },
      {
        "type": "checkbox",
        "id": "enable_order_note",
        "label": "t:labels.enable_order_note",
        "default": true
      },
      {
        "type": "text",
        "id": "order_note_label",
        "label": "t:labels.order_note_label",
        "default": "Order Note"
      },
      {
        "type": "text",
        "id": "order_note_placeholder",
        "label": "t:labels.order_note_placeholder",
        "default": "Add a note..."
      },
      {
        "type": "text",
        "id": "checkout_button_text",
        "label": "t:labels.checkout_button_text",
        "default": "Proceed to Checkout"
      },
      {
        "type": "text",
        "id": "continue_shopping_text",
        "label": "t:labels.continue_shopping_text",
        "default": "Continue Shopping"
      }
    ]
  }
]
