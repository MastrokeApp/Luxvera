{% comment %}
  Section: Hero Banner

  Fading hero slideshow with autoplay, arrows, dots, touch swipe,
  per-slide image + overlay, and an empty-state placeholder.
{% endcomment %}

{% assign slide_blocks = section.blocks | where: 'type', 'slide' %}
{% assign has_slides = false %}
{% if slide_blocks.size > 0 %}{% assign has_slides = true %}{% endif %}

<div
  class="hero-slideshow color-{{ section.settings.color_scheme }} gradient"
  id="hero-banner-{{ section.id }}"
  style="
    --hero-height-desktop:{{ section.settings.height_desktop }}px;
    --hero-height-tablet:{{ section.settings.height_tablet }}px;
    --hero-height-mobile:{{ section.settings.height_mobile }}px;
    --hero-content-align:{{ section.settings.content_alignment }};
    --hero-heading-size:{{ section.settings.heading_size }}px;
    --hero-heading-size-mobile:{{ section.settings.heading_size | times: 0.65 | round }}px;
  "
  aria-label="Hero slideshow"
  data-autoplay="{{ section.settings.autoplay }}"
  data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
>
  {%- if has_slides -%}

    {%- for block in slide_blocks -%}
      {%- assign is_first = false -%}
      {%- if forloop.index0 == 0 -%}{%- assign is_first = true -%}{%- endif -%}

      <div
        class="hero-slide{% if is_first %} is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        {{ block.shopify_attributes }}
        style="
          --slide-overlay-color:{{ block.settings.overlay_color }};
          --slide-overlay-opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};
        "
        aria-hidden="{% if is_first %}false{% else %}true{% endif %}"
      >
        <div class="hero-slide__bg">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1920 }}"
              alt="{{ block.settings.image.alt | escape }}"
              class="hero-slide__img"
              loading="{% if is_first %}eager{% else %}lazy{% endif %}"
              {% if is_first %}fetchpriority="high"{% endif %}
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {%- else -%}
            <div class="hero-slide__placeholder">
              {{- 'lifestyle-' | append: forloop.index | placeholder_svg_tag: 'hero-placeholder-svg' -}}
            </div>
          {%- endif -%}
          <div class="hero-slide__overlay"></div>
        </div>

        <div
          class="hero-slide__content"
          style="text-align:{{ section.settings.content_alignment | replace:'flex-start','left' | replace:'center','center' | replace:'flex-end','right' }};"
        >
          {%- if block.settings.heading != blank -%}
            {%- if template.name == 'index' -%}
              <h1 class="hero-slide__heading">{{ block.settings.heading | escape }}</h1>
            {%- else -%}
              <h2 class="hero-slide__heading">{{ block.settings.heading | escape }}</h2>
            {%- endif -%}
          {%- endif -%}

          {%- if block.settings.subtext != blank -%}
            <p class="hero-slide__subtext">{{ block.settings.subtext | escape }}</p>
          {%- endif -%}

          {%- if block.settings.button_label != blank and block.settings.button_url != blank -%}
            <a
              href="{{ block.settings.button_url }}"
              class="hero-slide__btn"
              {% if block.settings.button_open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
              {{ block.settings.button_label | escape }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- if slide_blocks.size > 1 -%}
      <button class="hero-arrow hero-arrow--prev" aria-label="Previous slide" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"/>
        </svg>
      </button>

      <button class="hero-arrow hero-arrow--next" aria-label="Next slide" type="button">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"/>
        </svg>
      </button>

      <div class="hero-dots" role="tablist" aria-label="Slide navigation">
        {%- for block in slide_blocks -%}
          <button
            class="hero-dot{% if forloop.index0 == 0 %} is-active{% endif %}"
            type="button"
            role="tab"
            aria-selected="{% if forloop.index0 == 0 %}true{% else %}false{% endif %}"
            aria-label="Go to slide {{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          ></button>
        {%- endfor -%}
      </div>
    {%- endif -%}

  {%- else -%}

    <div class="hero-slide is-active hero-slide--empty">
      <div class="hero-slide__bg">
        <div class="hero-slide__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-placeholder-svg' }}
        </div>
        <div class="hero-slide__overlay" style="--slide-overlay-color:#100a04;--slide-overlay-opacity:0.5;"></div>
      </div>
      <div class="hero-slide__content" style="text-align:center;">
        <h2 class="hero-slide__heading">Add Your First Slide</h2>
        <p class="hero-slide__subtext">Click "Add block → Slide" in the theme editor to get started.</p>
      </div>
    </div>

  {%- endif -%}
</div>

{% stylesheet %}
.hero-slideshow {
  position: relative;
  height: var(--hero-height-desktop, 580px);
  overflow: clip;
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.hero-slideshow .hero-slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.7s ease;
  z-index: 0;
}

.hero-slideshow .hero-slide.is-active {
  opacity: 1;
  pointer-events: auto;
  z-index: 1;
}

.hero-slideshow .hero-slide__bg {
  position: absolute;
  inset: 0;
}

.hero-slideshow .hero-slide__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
}

.hero-slideshow .hero-slide__placeholder {
  position: absolute;
  inset: 0;
  overflow: hidden;
  background: rgb(var(--color-background));
}

.hero-slideshow .hero-slide__placeholder .hero-placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hero-slideshow .hero-slide__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(16, 10, 4, calc(var(--slide-overlay-opacity, 0.6))) 32%,
    rgba(16, 10, 4, calc(var(--slide-overlay-opacity, 0.1) * 0.2)) 100%
  );
  background: linear-gradient(
    to right,
    color-mix(in srgb, var(--slide-overlay-color, #100a04) calc(var(--slide-overlay-opacity, 0.6) * 100%), transparent) 32%,
    color-mix(in srgb, var(--slide-overlay-color, #100a04) calc(var(--slide-overlay-opacity, 0.1) * 10%), transparent) 100%
  );
}

.hero-slideshow .hero-slide__content {
  position: relative;
  z-index: 2;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 56px;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: var(--hero-content-align, flex-start);
}

@keyframes luxvera-fade-up {
  from {
    opacity: 0;
    transform: translateY(22px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.hero-slideshow .hero-slide.is-active .hero-slide__heading {
  animation: luxvera-fade-up 0.7s ease both;
  animation-delay: 0.2s;
}

.hero-slideshow .hero-slide.is-active .hero-slide__subtext {
  animation: luxvera-fade-up 0.7s ease both;
  animation-delay: 0.38s;
}

.hero-slideshow .hero-slide.is-active .hero-slide__btn {
  animation: luxvera-fade-up 0.7s ease both;
  animation-delay: 0.52s;
}

.hero-slideshow .hero-slide__heading {
  color: rgb(var(--color-foreground));
  font-size: var(--hero-heading-size, 48px);
  font-weight: 500;
  line-height: 1.15;
  margin: 0 0 20px;
  max-width: 720px;
}

.hero-slideshow .hero-slide__subtext {
  color: rgb(var(--color-foreground));
  font-size: 18px;
  font-weight: 400;
  margin: 0;
  max-width: 480px;
  opacity: 0.88;
}

.hero-slideshow .hero-slide__btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 0 34px;
  margin-top: 36px;
  border: 1px solid rgb(var(--color-button));
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  text-decoration: none;
  white-space: nowrap;
  transition: all 0.3s ease;
}

.hero-slideshow .hero-slide__btn:hover {
  background: #fff;
  color: rgb(var(--color-button));
  transform: translateY(-2px);
}

.hero-slideshow .hero-arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 10;
  background: rgba(var(--color-background), 0.35);
  border: 1px solid rgba(var(--color-foreground), 0.25);
  color: rgb(var(--color-foreground));
  width: 48px;
  height: 48px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background 0.25s, transform 0.25s;
  backdrop-filter: blur(4px);
}

.hero-slideshow .hero-arrow:hover {
  background: rgba(var(--color-background), 0.55);
  transform: translateY(-50%) scale(1.08);
}

.hero-slideshow .hero-arrow--prev {
  left: 24px;
}

.hero-slideshow .hero-arrow--next {
  right: 24px;
}

.hero-slideshow .hero-dots {
  position: absolute;
  bottom: 24px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
  display: flex;
  gap: 8px;
  align-items: center;
}

.hero-slideshow .hero-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(var(--color-foreground), 0.45);
  border: none;
  cursor: pointer;
  padding: 0;
  transition: background 0.3s, transform 0.3s;
}

.hero-slideshow .hero-dot.is-active {
  background: rgb(var(--color-foreground));
  transform: scale(1.35);
}

@media (max-width: 768px) {
  .hero-slideshow {
    height: var(--hero-height-tablet, 420px);
  }

  .hero-slideshow .hero-slide__content {
    padding: 0 28px;
  }

  .hero-slideshow .hero-arrow {
    width: 40px;
    height: 40px;
  }

  .hero-slideshow .hero-arrow--prev {
    left: 12px;
  }

  .hero-slideshow .hero-arrow--next {
    right: 12px;
  }
}

@media (max-width: 480px) {
  .hero-slideshow {
    height: var(--hero-height-mobile, 360px);
  }

  .hero-slideshow .hero-slide__content {
    padding: 0 24px;
    align-items: var(--hero-content-align, flex-start);
  }

  .hero-slideshow .hero-slide__heading {
    font-size: var(--hero-heading-size-mobile, 31px);
    margin-bottom: 16px;
  }

  .hero-slideshow .hero-slide__subtext {
    font-size: 15px;
    line-height: 1.6;
  }

  .hero-slideshow .hero-slide__btn {
    width: 100%;
    max-width: 200px;
    margin-top: 28px;
  }

  .hero-slideshow .hero-arrow {
    display: none;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  function initHeroSlideshow(root) {
    if (!root || root.dataset.lvHeroInit) return;
    root.dataset.lvHeroInit = '1';

    var slides = Array.prototype.slice.call(root.querySelectorAll('.hero-slide'));
    var dots   = Array.prototype.slice.call(root.querySelectorAll('.hero-dot'));
    var prev   = root.querySelector('.hero-arrow--prev');
    var next   = root.querySelector('.hero-arrow--next');
    var total  = slides.length;

    if (total <= 1) return;

    var current  = 0;
    var autoplay = root.dataset.autoplay === 'true';
    var speed    = parseInt(root.dataset.speed, 10) || 5000;
    var timer    = null;

    function goTo(index) {
      slides[current].classList.remove('is-active');
      slides[current].setAttribute('aria-hidden', 'true');

      if (dots[current]) {
        dots[current].classList.remove('is-active');
        dots[current].setAttribute('aria-selected', 'false');
      }

      current = (index + total) % total;

      slides[current].classList.add('is-active');
      slides[current].setAttribute('aria-hidden', 'false');

      if (dots[current]) {
        dots[current].classList.add('is-active');
        dots[current].setAttribute('aria-selected', 'true');
      }
    }

    function startAuto() {
      if (!autoplay) return;
      clearInterval(timer);
      timer = setInterval(function () {
        goTo(current + 1);
      }, speed);
    }

    function stopAuto() {
      clearInterval(timer);
    }

    if (prev) {
      prev.addEventListener('click', function () {
        stopAuto();
        goTo(current - 1);
        startAuto();
      });
    }

    if (next) {
      next.addEventListener('click', function () {
        stopAuto();
        goTo(current + 1);
        startAuto();
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        stopAuto();
        goTo(parseInt(this.dataset.index, 10));
        startAuto();
      });
    });

    root.addEventListener('mouseenter', stopAuto);
    root.addEventListener('mouseleave', startAuto);

    var touchStartX = 0;

    root.addEventListener('touchstart', function (e) {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    root.addEventListener('touchend', function (e) {
      var diff = touchStartX - e.changedTouches[0].screenX;
      if (Math.abs(diff) > 40) {
        stopAuto();
        goTo(diff > 0 ? current + 1 : current - 1);
        startAuto();
      }
    }, { passive: true });

    // Expose cleanup so the theme editor can stop the timer on unload
    root.lvHeroStop = stopAuto;

    startAuto();
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('.hero-slideshow').forEach(function (el) {
      initHeroSlideshow(el);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  // Theme-editor lifecycle
  document.addEventListener('shopify:section:load', function (e) {
    initAll(e.target);
  });

  document.addEventListener('shopify:section:unload', function (e) {
    var el = e.target && e.target.querySelector ? e.target.querySelector('.hero-slideshow') : null;
    if (el && typeof el.lvHeroStop === 'function') el.lvHeroStop();
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "luxvera-hero-banner",
  "limit": 1,
  "settings": [
    { "type": "header", "content": "Section Height" },
    { "type": "range", "id": "height_desktop", "label": "Desktop Height", "min": 200, "max": 900, "step": 10, "unit": "px", "default": 580 },
    { "type": "range", "id": "height_tablet", "label": "Tablet Height", "min": 240, "max": 700, "step": 10, "unit": "px", "default": 420 },
    { "type": "range", "id": "height_mobile", "label": "Mobile Height", "min": 200, "max": 600, "step": 10, "unit": "px", "default": 360 },

    { "type": "header", "content": "Content" },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "range", "id": "heading_size", "label": "Heading Font Size", "min": 28, "max": 96, "step": 2, "unit": "px", "default": 48 },

    { "type": "header", "content": "Autoplay" },
    { "type": "checkbox", "id": "autoplay", "label": "Auto-rotate slides", "default": false },
    { "type": "range", "id": "autoplay_speed", "label": "Speed (seconds)", "min": 3, "max": 10, "step": 1, "unit": "s", "default": 5 }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "header", "content": "Background" },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image",
          "info": "Recommended: 1920×1080px JPG/WebP. Leave blank to show a placeholder."
        },
        { "type": "color", "id": "overlay_color", "label": "Overlay Colour", "default": "#100a04" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay Opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 60 },

        { "type": "header", "content": "Content" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Western Soul, Modern Style" },
        {
          "type": "textarea",
          "id": "subtext",
          "label": "Subtext",
          "default": "From laid-back daytime to summer nights — discover Western style crafted for you."
        },

        { "type": "header", "content": "Button" },
        { "type": "text", "id": "button_label", "label": "Button Label", "default": "Shop the Collection" },
        { "type": "url", "id": "button_url", "label": "Button URL" },
        { "type": "checkbox", "id": "button_open_new_tab", "label": "Open in new tab", "default": false }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Western Soul, Modern Style",
            "subtext": "From laid-back daytime to summer nights — discover Western style crafted for you.",
            "button_label": "Shop the Collection",
            "button_url": "/collections/all"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "New Arrivals Are Here",
            "subtext": "Explore our latest styles — fresh drops every week.",
            "button_label": "Shop New Arrivals",
            "button_url": "/collections/new-arrival"
          }
        }
      ]
    }
  ]
}
{% endschema %}
