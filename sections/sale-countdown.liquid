{% comment %}
  Section: Sale Countdown

  Promo bar with eyebrow, heading, CTA and a live days/hours/minutes/seconds
  countdown. End date is set in the editor; falls back to 6 days from now.
  Note: the countdown uses each visitor's local time zone.
{% endcomment %}

<div
  class="sale-section color-{{ section.settings.color_scheme }} gradient"
  id="sale-countdown-{{ section.id }}"
  data-end="{{ section.settings.countdown_end | strip }}"
  style="
    --sc-pt: {{ section.settings.padding_top | default: 40 }}px;
    --sc-pb: {{ section.settings.padding_bottom | default: 40 }}px;
    --sc-heading-size: {{ section.settings.heading_size | default: 28 }}px;
  "
>
  <div class="sale-inner">
    <div class="sale-text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="sale-eyebrow">{{ section.settings.eyebrow | escape }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}" class="sale-btn">
          {{ section.settings.button_label | escape }} →
        </a>
      {%- endif -%}
    </div>

    <div class="sale-divider" aria-hidden="true"></div>

    <div class="sale-right">
      <div class="count-box">
        <span class="count-num lv-days">00</span>
        <span class="count-label">{{ section.settings.label_days | default: 'Days' }}</span>
      </div>
      <div class="count-box">
        <span class="count-num lv-hours">00</span>
        <span class="count-label">{{ section.settings.label_hours | default: 'Hours' }}</span>
      </div>
      <div class="count-box">
        <span class="count-num lv-minutes">00</span>
        <span class="count-label">{{ section.settings.label_minutes | default: 'Minutes' }}</span>
      </div>
      <div class="count-box">
        <span class="count-num lv-seconds">00</span>
        <span class="count-label">{{ section.settings.label_seconds | default: 'Seconds' }}</span>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.sale-section {
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
  border-top: 1px solid rgba(var(--color-foreground), 0.12);
  border-bottom: 1px solid rgba(var(--color-foreground), 0.12);
}

.sale-section .sale-inner {
  max-width: var(--lv-container-max, 1280px);
  margin: 0 auto;
  padding: var(--sc-pt, 40px) 56px var(--sc-pb, 40px);
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  align-items: center;
}

.sale-section .sale-divider {
  width: 1px;
  height: 80px;
  background: rgba(var(--color-foreground), 0.12);
  justify-self: center;
}

.sale-section .sale-text {
  padding-right: 56px;
}

.sale-section .sale-eyebrow {
  display: block;
  font-size: 12px;
  color: rgb(var(--color-foreground));
  opacity: 0.55;
  margin-bottom: 8px;
}

.sale-section .sale-text h2 {
  font-size: var(--sc-heading-size, 28px);
  font-weight: 500;
  color: rgb(var(--color-foreground));
  line-height: 1.2;
  margin-bottom: 16px;
}

.sale-section .sale-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  font-size: 11px;
  font-weight: 500;
  letter-spacing: .04em;
  padding: 9px 18px;
  border: none;
  border-radius: var(--lv-btn-radius, 0px);
  text-decoration: none;
  transition: opacity .2s;
}

.sale-section .sale-btn:hover {
  opacity: 0.82;
}

.sale-section .sale-right {
  padding-left: 56px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12px;
}

.sale-section .count-box {
  background: rgba(var(--color-foreground), 0.06);
  text-align: center;
  min-width: 80px;
  padding: 14px 12px 12px;
  border-radius: 8px;
}

.sale-section .count-num {
  font-size: 32px;
  font-weight: 700;
  line-height: 1;
  display: block;
  color: rgb(var(--color-foreground));
}

.sale-section .count-label {
  font-size: 11px;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: rgb(var(--color-foreground));
  opacity: 0.5;
  margin-top: 5px;
  display: block;
}

@media (max-width: 1024px) {
  .sale-section .sale-inner {
    padding-left: 32px;
    padding-right: 32px;
  }

  .sale-section .sale-text {
    padding-right: 32px;
  }

  .sale-section .sale-right {
    padding-left: 32px;
  }
}

@media (max-width: 768px) {
  .sale-section .sale-inner {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 36px 20px;
  }

  .sale-section .sale-divider {
    display: none;
  }

  .sale-section .sale-text {
    padding-right: 0;
  }

  .sale-section .sale-right {
    padding-left: 0;
    flex-wrap: wrap;
    justify-content: flex-start;
  }
}

@media (max-width: 480px) {
  .sale-section .sale-right {
    gap: 8px;
  }

  .sale-section .count-box {
    min-width: 60px;
    padding: 12px 8px 10px;
  }

  .sale-section .count-num {
    font-size: 26px;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  function pad(n) {
    return String(n).padStart(2, '0');
  }

  function parseCountdownDate(str) {
    if (!str) return null;

    /* Accept both:
       2025-08-31T23:59:00
       2025-08-31 23:59:00
    */
    str = str.replace('T', ' ').trim();

    var parts = str.split(' ');
    if (parts.length < 2) return null;

    var dateParts = parts[0].split('-');
    var timeParts = parts[1].split(':');

    if (dateParts.length !== 3) return null;

    var year   = parseInt(dateParts[0], 10);
    var month  = parseInt(dateParts[1], 10) - 1;
    var day    = parseInt(dateParts[2], 10);
    var hour   = parseInt(timeParts[0] || 0, 10);
    var minute = parseInt(timeParts[1] || 0, 10);
    var second = parseInt(timeParts[2] || 0, 10);

    var parsed = new Date(year, month, day, hour, minute, second);

    if (isNaN(parsed.getTime())) return null;
    return parsed;
  }

  function initCountdown(el) {
    if (el.dataset.lvCountdownInit) return;
    el.dataset.lvCountdownInit = '1';

    var endStr = (el.dataset.end || '').trim();
    var deadline = parseCountdownDate(endStr);

    /* fallback if no valid date */
    if (!deadline) {
      deadline = new Date(Date.now() + 6 * 24 * 60 * 60 * 1000);
    }

    var days  = el.querySelector('.lv-days');
    var hours = el.querySelector('.lv-hours');
    var mins  = el.querySelector('.lv-minutes');
    var secs  = el.querySelector('.lv-seconds');

    function tick() {
      var diff = deadline.getTime() - Date.now();

      if (diff <= 0) {
        if (days) days.textContent = '00';
        if (hours) hours.textContent = '00';
        if (mins) mins.textContent = '00';
        if (secs) secs.textContent = '00';
        clearInterval(el.lvCountdownTimer);
        return;
      }

      var d = Math.floor(diff / 86400000);
      var h = Math.floor((diff % 86400000) / 3600000);
      var m = Math.floor((diff % 3600000) / 60000);
      var s = Math.floor((diff % 60000) / 1000);

      if (days) days.textContent = pad(d);
      if (hours) hours.textContent = pad(h);
      if (mins) mins.textContent = pad(m);
      if (secs) secs.textContent = pad(s);
    }

    tick();
    clearInterval(el.lvCountdownTimer);
    el.lvCountdownTimer = setInterval(tick, 1000);
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('.sale-section').forEach(initCountdown);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  // Theme-editor lifecycle
  document.addEventListener('shopify:section:load', function (e) {
    initAll(e.target);
  });

  document.addEventListener('shopify:section:unload', function (e) {
    var el = e.target && e.target.querySelector ? e.target.querySelector('.sale-section') : null;
    if (el && el.lvCountdownTimer) clearInterval(el.lvCountdownTimer);
  });
})();
{% endjavascript %}

{% schema %}
