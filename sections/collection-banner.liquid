{% comment %}
  Banner at the top of collection pages - bg image, gradient overlay,
  breadcrumbs (Home / Collection), heading + subtext. If heading/breadcrumb
  aren't set manually they just fall back to the collection's title.

  Goes with the main-collection section.
{% endcomment %}

{%- liquid
  assign banner_heading = section.settings.heading
  if banner_heading == blank
    assign banner_heading = collection.title
  endif

  assign banner_subtext = section.settings.subtext
  if banner_subtext == blank
    assign banner_subtext = collection.description
  endif

  assign text_align = 'left'
  if section.settings.content_alignment == 'center'
    assign text_align = 'center'
  elsif section.settings.content_alignment == 'flex-end'
    assign text_align = 'right'
  endif
-%}

<div
  class="lv-collection-banner color-{{ section.settings.color_scheme }}"
  id="lv-collection-banner-{{ section.id }}"
  style="
    --lv-cb-height-desktop: {{ section.settings.height_desktop }}px;
    --lv-cb-height-tablet: {{ section.settings.height_tablet }}px;
    --lv-cb-height-mobile: {{ section.settings.height_mobile }}px;
    --lv-cb-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --lv-cb-overlay-color: {{ section.settings.overlay_color }};
    --lv-cb-content-align: {{ section.settings.content_alignment }};
    --lv-cb-text-align: {{ text_align }};
    --lv-cb-heading-size: {{ section.settings.heading_size }}px;
    --lv-cb-heading-size-mobile: {{ section.settings.heading_size | times: 0.65 | round }}px;
  "
>
  <div class="lv-collection-banner__bg">
    {%- if section.settings.background_image != blank -%}
      <div
        class="lv-collection-banner__bg-image"
        style="background-image:
          linear-gradient(
            to right,
            color-mix(in srgb, {{ section.settings.overlay_color }} calc(var(--lv-cb-overlay-opacity) * 100%), transparent) 32%,
            color-mix(in srgb, {{ section.settings.overlay_color }} calc(var(--lv-cb-overlay-opacity) * 10%), transparent) 100%
          ),
          url('{{ section.settings.background_image | image_url: width: 1920 }}');"
      ></div>
    {%- else -%}
      <div class="lv-collection-banner__bg-placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'lv-collection-banner__placeholder-svg' }}
      </div>
    {%- endif -%}
  </div>

  <div class="lv-collection-banner__content">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="lv-collection-banner__breadcrumbs" aria-label="Breadcrumb">
        <ol class="lv-collection-banner__breadcrumbs-list">
          <li class="lv-collection-banner__breadcrumbs-item">
            <a class="lv-collection-banner__breadcrumbs-link" href="{{ routes.root_url }}">
              {{ section.settings.breadcrumb_home_label | default: 'Home' | escape }}
            </a>
          </li>
          <li class="lv-collection-banner__breadcrumbs-item" aria-current="page">
            {{ collection.title | escape }}
          </li>
        </ol>
      </nav>
    {%- endif -%}

    {%- if banner_heading != blank -%}
      <h1 class="lv-collection-banner__heading">{{ banner_heading | escape }}</h1>
    {%- endif -%}

    {%- if banner_subtext != blank -%}
      <div class="lv-collection-banner__subtext rte">{{ banner_subtext }}</div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.lv-collection-banner {
  position: relative;
  height: var(--lv-cb-height-desktop, 420px);
  overflow: clip;
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.lv-collection-banner .lv-collection-banner__bg,
.lv-collection-banner .lv-collection-banner__bg-image,
.lv-collection-banner .lv-collection-banner__bg-placeholder {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.lv-collection-banner .lv-collection-banner__bg-image {
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.lv-collection-banner .lv-collection-banner__bg-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgb(var(--color-background));
  overflow: hidden;
}

.lv-collection-banner .lv-collection-banner__placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.lv-collection-banner .lv-collection-banner__placeholder-svg svg {
  width: 100%;
  height: 100%;
}

@keyframes lv-collection-banner-zoom {
  from { transform: scale(1.04); }
  to { transform: scale(1); }
}

.lv-collection-banner .lv-collection-banner__bg-image,
.lv-collection-banner .lv-collection-banner__bg-placeholder {
  animation: lv-collection-banner-zoom 1.4s cubic-bezier(.25, .46, .45, .94) forwards;
}

.lv-collection-banner .lv-collection-banner__content {
  position: relative;
  z-index: 2;
  max-width: var(--lv-container-max, 1280px);
  margin: 0 auto;
  padding: 0 56px;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: var(--lv-cb-content-align, flex-start);
  text-align: var(--lv-cb-text-align, left);
}

@keyframes lv-collection-banner-fade-up {
  from {
    opacity: 0;
    transform: translateY(22px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.lv-collection-banner .lv-collection-banner__breadcrumbs {
  animation: lv-collection-banner-fade-up .7s ease both;
  animation-delay: .2s;
  margin: 0 0 18px;
}

.lv-collection-banner .lv-collection-banner__heading {
  animation: lv-collection-banner-fade-up .7s ease both;
  animation-delay: .38s;
  color: rgb(var(--color-foreground));
  font-size: var(--lv-cb-heading-size, 42px);
  font-weight: 500;
  line-height: 1.15;
  margin: 0 0 20px;
  max-width: 720px;
}

.lv-collection-banner .lv-collection-banner__subtext {
  animation: lv-collection-banner-fade-up .7s ease both;
  animation-delay: .52s;
  color: rgb(var(--color-foreground));
  font-size: 18px;
  font-weight: 400;
  margin: 0;
  max-width: 480px;
  opacity: .88;
}

.lv-collection-banner .lv-collection-banner__subtext p {
  margin: 0;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-item {
  display: flex;
  align-items: center;
  font-size: 12px;
  font-weight: 400;
  text-transform: uppercase;
  letter-spacing: .18em;
  color: rgb(var(--color-foreground));
  opacity: .75;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-item + .lv-collection-banner__breadcrumbs-item::before {
  content: '';
  display: inline-block;
  width: 5px;
  height: 5px;
  border-right: 1.5px solid currentColor;
  border-top: 1.5px solid currentColor;
  transform: rotate(45deg);
  margin: 0 10px;
  opacity: .6;
  flex-shrink: 0;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-item[aria-current="page"] {
  opacity: 1;
  font-weight: 600;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-link {
  color: inherit;
  text-decoration: none;
  transition: opacity .2s;
}

.lv-collection-banner .lv-collection-banner__breadcrumbs-link:hover {
  opacity: 1;
  text-decoration: underline;
  text-underline-offset: 3px;
}

@media (max-width: 768px) {
  .lv-collection-banner {
    height: var(--lv-cb-height-tablet, 320px);
  }

  .lv-collection-banner .lv-collection-banner__content {
    padding: 0 28px;
  }
}

@media (max-width: 480px) {
  .lv-collection-banner {
    height: var(--lv-cb-height-mobile, 260px);
  }

  .lv-collection-banner .lv-collection-banner__content {
    padding: 0 24px;
    justify-content: center;
  }

  .lv-collection-banner .lv-collection-banner__heading {
    font-size: var(--lv-cb-heading-size-mobile, 27px);
    margin-bottom: 16px;
  }

  .lv-collection-banner .lv-collection-banner__subtext {
    font-size: 15px;
    line-height: 1.6;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Collection Banner",
  "tag": "section",
  "class": "luxvera-collection-banner",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Recommended: 1920 × 1080px"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#100a04"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 70
    },

    {
      "type": "header",
      "content": "Section height"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "default": 420
    },
    {
      "type": "range",
      "id": "height_tablet",
      "label": "Tablet height",
      "min": 180,
      "max": 600,
      "step": 10,
      "unit": "px",
      "default": 320
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 160,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 260
    },

    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },

    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "text",
      "id": "breadcrumb_home_label",
      "label": "Home label",
      "default": "Home"
    },

    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use the collection title."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 42
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "info": "Leave blank to use the collection description."
    }
  ],
  "presets": [
    {
      "name": "Collection Banner"
    }
  ]
}
{% endschema %}
