{% comment %}
  Section: Main Search

  Renders search results on the search template. Product results render through
  the shared product-card snippet (same layout as the collection grid); article
  and page results render as simple linked cards. A filter sidebar (reusing the
  same lv-filter-group markup/behaviour as sections/collection.liquid) lets
  shoppers narrow product results using Shopify's storefront filtering. Colors
  follow the selected color scheme.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search

  Depends on:
    - snippets/product-card.liquid
    - lv-variant-modal.css (for multi-variant card add-to-cart, if used)
{% endcomment %}

{{ 'lv-variant-modal.css' | asset_url | stylesheet_tag }}

<div
  class="lv-search color-{{ section.settings.color_scheme }}"
  id="lv-search-{{ section.id }}"
  data-lv-search-id="{{ section.id }}"
  data-search-terms="{{ search.terms | escape }}"
  style="
    --lv-search-pt: {{ section.settings.padding_top }}px;
    --lv-search-pb: {{ section.settings.padding_bottom }}px;
    --lv-search-gap: {{ section.settings.grid_gap }}px;
    --lv-search-gap-row: {{ section.settings.grid_gap_row }}px;
    --lv-search-cols-d: {{ section.settings.columns_desktop }};
    --lv-search-cols-t: {{ section.settings.columns_tablet }};
    --lv-search-cols-m: {{ section.settings.columns_mobile }};
    --lv-card-radius: {{ section.settings.card_radius }}px;
    --lv-btn-radius: {{ section.settings.button_radius }}px;
  "
>
  <div class="lv-search-inner">
    <h1 class="lv-search-title">{{ section.settings.heading | default: 'Search' | escape }}</h1>

    <form action="{{ routes.search_url }}" method="get" role="search" class="lv-search-form">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ section.settings.placeholder | default: 'Search our store' | escape }}"
        class="lv-search-input"
        aria-label="{{ 'accessibility.search' | t }}"
      >
      <button type="submit" class="lv-search-submit">{{ section.settings.submit_label | default: 'Search' | escape }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count == 0 -%}
        <p class="lv-search-empty">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {%- else -%}
        <p class="lv-search-count">{{ 'search.results_for_html' | t: count: search.results_count, terms: search.terms }}</p>

        <div class="lv-search-body{% unless section.settings.show_filters %} lv-search-body--no-sidebar{% endunless %}">
          {%- if section.settings.show_filters -%}
            <aside class="lv-search-sidebar">
              <div class="lv-sidebar-inner">
                <p class="lv-sidebar__heading">{{ section.settings.filter_heading | default: 'FILTER BY' }}</p>

                {%- if search.filters != empty -%}
                  <form class="lv-filters-form" id="lv-filters-form-{{ section.id }}">
                    {%- for filter in search.filters -%}
                      <div class="lv-filter-group" data-filter-type="{{ filter.type }}">
                        <button type="button" class="lv-filter-group__toggle">
                          {{ filter.label | upcase }}
                          <span class="lv-fg-arrow" aria-hidden="true">&#8722;</span>
                        </button>

                        <div class="lv-filter-group__body">
                          {%- case filter.type -%}
                            {%- when 'boolean' or 'list' -%}
                              {%- for filter_value in filter.values -%}
                                <label class="lv-filter-check">
                                  <input
                                    type="checkbox"
                                    name="{{ filter_value.param_name }}"
                                    value="{{ filter_value.value }}"
                                    {% if filter_value.active %}checked{% endif %}
                                    {% if filter_value.count == 0 and filter_value.active == false %}disabled{% endif %}
                                  >
                                  <span>{{ filter_value.label }}</span>
                                  <span class="lv-filter-count">({{ filter_value.count }})</span>
                                </label>
                              {%- endfor -%}

                            {%- when 'price_range' -%}
                              <div class="lv-price-range">
                                <input
                                  class="lv-price-input"
                                  type="number"
                                  name="{{ filter.min_value.param_name }}"
                                  value="{% if filter.min_value.value %}{{ filter.min_value.value | money_without_currency | replace: ',', '' }}{% endif %}"
                                  placeholder="{{ 'collections.filter_min' | t }}"
                                  min="0"
                                >
                                <input
                                  class="lv-price-input"
                                  type="number"
                                  name="{{ filter.max_value.param_name }}"
                                  value="{% if filter.max_value.value %}{{ filter.max_value.value | money_without_currency | replace: ',', '' }}{% endif %}"
                                  placeholder="{{ 'collections.filter_max' | t }}"
                                  min="0"
                                >
                              </div>
                              <button type="submit" class="lv-apply-btn">{{ 'collections.filter_apply' | t }}</button>
                          {%- endcase -%}
                        </div>
                      </div>
                    {%- endfor -%}

                    <div class="lv-filter-actions">
                      <a class="lv-clear-filters" href="{{ routes.search_url }}?q={{ search.terms | url_encode }}">{{ 'collections.filter_clear_all' | t }}</a>
                    </div>
                  </form>
                {%- else -%}
                  <p class="lv-no-filters-msg">{{ 'collections.filters_unavailable' | t }}</p>
                {%- endif -%}
              </div>
            </aside>
          {%- endif -%}

          <div class="lv-search-grid-wrap">
            {%- paginate search.results by section.settings.results_per_page -%}
              <div class="lv-search-grid">
                {%- for result in search.results -%}
                  {%- case result.object_type -%}

                    {%- when 'product' -%}
                      {% render 'product-card',
                        product: result,
                        card_context: 'collection',
                        atc_label: section.settings.atc_label,
                        image_ratio: section.settings.image_ratio
                      %}

                    {%- else -%}
                      {%- comment -%} Article or page result {%- endcomment -%}
                      <a class="lv-search-card lv-search-card--{{ result.object_type }}" href="{{ result.url }}">
                        {%- assign result_image = result.featured_image | default: result.image -%}
                        <div class="lv-search-card__media">
                          {%- if result_image -%}
                            <img
                              src="{{ result_image | image_url: width: 600 }}"
                              alt="{{ result.title | escape }}"
                              width="600"
                              height="600"
                              loading="lazy"
                            >
                          {%- else -%}
                            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                          {%- endif -%}
                        </div>
                        <div class="lv-search-card__body">
                          <span class="lv-search-card__type">{{ result.object_type }}</span>
                          <p class="lv-search-card__title">{{ result.title | escape }}</p>
                        </div>
                      </a>

                  {%- endcase -%}
                {%- endfor -%}
              </div>

              {%- if paginate.pages > 1 -%}
                <div class="lv-search-pagination">
                  {{ paginate | default_pagination }}
                </div>
              {%- endif -%}
            {%- endpaginate -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- comment -%} Size picker for multi-variant products {%- endcomment -%}
  <div class="lv-variant-modal" id="lv-vm-search-{{ section.id }}" role="dialog" aria-modal="true" aria-label="{{ 'products.select_size' | t }}">
    <div class="lv-variant-modal__box">
      <div class="lv-variant-modal__head">
        <span class="lv-variant-modal__title" id="lv-vm-search-title-{{ section.id }}"></span>
        <button class="lv-variant-modal__close" id="lv-vm-search-close-{{ section.id }}" aria-label="{{ 'accessibility.close' | t }}">&times;</button>
      </div>
      <p class="lv-variant-modal__label">{{ 'products.select_size' | t }}</p>
      <div class="lv-variant-modal__options" id="lv-vm-search-opts-{{ section.id }}"></div>
      <button
        class="lv-variant-modal__atc"
        id="lv-vm-search-atc-{{ section.id }}"
        data-label-choose="{{ 'products.choose_a_size' | t }}"
        data-label-add-prefix="{{ 'products.add_to_cart_prefix' | t }}"
        data-label-adding="{{ 'products.adding' | t }}"
        disabled
      >{{ 'products.choose_a_size' | t }}</button>
    </div>
  </div>
</div>

{% stylesheet %}
.lv-search {
  padding-top: var(--lv-search-pt, 48px);
  padding-bottom: var(--lv-search-pb, 64px);
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.lv-search .lv-search-inner {
  max-width: var(--lv-container-max, 1280px);
  margin: 0 auto;
  padding: 0 56px;
}

.lv-search .lv-search-title {
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 700;
  font-family: var(--lv-font-heading, serif);
  color: rgb(var(--color-foreground));
  margin: 0 0 24px;
}

/* Search form */
.lv-search .lv-search-form {
  display: flex;
  gap: 0;
  max-width: 560px;
  margin: 0 0 32px;
  border: 1px solid rgba(var(--color-foreground), 0.25);
  border-radius: 4px;
  overflow: hidden;
}

.lv-search .lv-search-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 13px 16px;
  font-size: 14px;
  color: rgb(var(--color-foreground));
  outline: none;
  min-width: 0;
}

.lv-search .lv-search-input::placeholder {
  color: rgba(var(--color-foreground), 0.5);
}

.lv-search .lv-search-submit {
  border: none;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  padding: 13px 24px;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity .2s;
}

.lv-search .lv-search-submit:hover {
  opacity: .85;
}

/* Result counts / empty */
.lv-search .lv-search-count {
  font-size: 13px;
  color: rgb(var(--color-foreground));
  opacity: .7;
  margin: 0 0 24px;
}

.lv-search .lv-search-empty {
  font-size: 15px;
  color: rgb(var(--color-foreground));
  opacity: .7;
  padding: 32px 0;
}

/* Filters + results layout */
.lv-search .lv-search-body {
  display: flex;
  align-items: flex-start;
  gap: 40px;
}

.lv-search .lv-search-body--no-sidebar .lv-search-grid-wrap {
  width: 100%;
}

.lv-search .lv-search-sidebar {
  width: 240px;
  flex-shrink: 0;
}

.lv-search .lv-sidebar-inner {
  border: 1px solid rgba(var(--color-foreground), 0.14);
  padding: 20px;
  background: rgb(var(--color-background));
}

.lv-search .lv-sidebar__heading {
  margin: 0 0 16px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .12em;
  color: rgb(var(--color-foreground));
  opacity: .75;
}

.lv-search .lv-filter-group {
  border-top: 1px solid rgba(var(--color-foreground), 0.14);
  padding: 14px 0;
}

.lv-search .lv-filter-group:first-child {
  border-top: none;
  padding-top: 0;
}

.lv-search .lv-filter-group__toggle {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  cursor: pointer;
  background: none;
  border: none;
  padding: 0;
  color: rgb(var(--color-foreground));
  text-align: left;
}

.lv-search .lv-fg-arrow {
  font-size: 16px;
  line-height: 1;
  color: rgb(var(--color-foreground));
  opacity: .55;
}

.lv-search .lv-filter-group__body {
  margin-top: 14px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lv-search .lv-filter-group__body.collapsed {
  display: none;
}

.lv-search .lv-filter-check {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  cursor: pointer;
  flex-wrap: wrap;
  color: rgb(var(--color-foreground));
}

.lv-search .lv-filter-check input[type="checkbox"] {
  width: 15px;
  height: 15px;
  cursor: pointer;
}

.lv-search .lv-filter-count {
  opacity: .55;
}

.lv-search .lv-price-range {
  display: flex;
  gap: 8px;
  margin-bottom: 10px;
}

.lv-search .lv-price-input {
  width: 100%;
  padding: 10px 12px;
  font-size: 13px;
  border: 1px solid rgba(var(--color-foreground), 0.18);
  background: rgb(var(--color-background));
  color: rgb(var(--color-foreground));
}

.lv-search .lv-apply-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: 12px;
  border: none;
  cursor: pointer;
  transition: opacity .2s;
}

.lv-search .lv-apply-btn:hover {
  opacity: .8;
}

.lv-search .lv-filter-actions {
  margin-top: 16px;
}

.lv-search .lv-clear-filters {
  display: inline-block;
  font-size: 12px;
  text-decoration: underline;
  color: rgb(var(--color-foreground));
}

.lv-search .lv-no-filters-msg {
  margin: 0;
  font-size: 13px;
  opacity: .65;
}

/* Results grid */
.lv-search .lv-search-grid-wrap {
  flex: 1;
  min-width: 0;
}

.lv-search .lv-search-grid {
  display: grid;
  grid-template-columns: repeat(var(--lv-search-cols-d, 4), minmax(0, 1fr));
  gap: var(--lv-search-gap-row, 32px) var(--lv-search-gap, 20px);
}

.lv-search .lv-search-body--no-sidebar .lv-search-grid {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

/* Product card shared styling (mirrors collection grid) */
.lv-search .product-card {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.lv-search .product-img-wrap {
  position: relative;
  overflow: hidden;
  display: block;
  text-decoration: none;
  background: rgb(var(--color-background));
  border-radius: var(--lv-card-radius, 6px) var(--lv-card-radius, 6px) 0 0;
}

.lv-search .product-img-wrap--portrait { aspect-ratio: 3/4; }
.lv-search .product-img-wrap--square { aspect-ratio: 1/1; }
.lv-search .product-img-wrap--landscape { aspect-ratio: 4/3; }

.lv-search .product-img-wrap img,
.lv-search .product-img-wrap .placeholder-svg {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
  transition: transform .35s ease;
}

.lv-search .product-card:hover .product-img-wrap img {
  transform: scale(1.04);
}

.lv-search .product-info {
  background: rgb(var(--color-background));
  border: 1px solid rgba(var(--color-foreground), 0.14);
  border-top: none;
  border-radius: 0 0 var(--lv-card-radius, 6px) var(--lv-card-radius, 6px);
  padding: 14px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.lv-search .product-name {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.45;
  color: rgb(var(--color-foreground));
  text-decoration: none;
  margin-bottom: 6px;
}

.lv-search .product-name:hover {
  opacity: .75;
}

.lv-search .price-color-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px;
  margin-bottom: 12px;
}

.lv-search .price-new {
  font-size: 14px;
  font-weight: 500;
  color: rgb(var(--color-foreground));
}

.lv-search .price-old {
  font-size: 13px;
  color: rgb(var(--color-foreground));
  opacity: .5;
  text-decoration: line-through;
}

.lv-search .add-to-cart {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  width: 100%;
  margin-top: auto;
  padding: 13px 16px;
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  border: none;
  border-radius: var(--lv-btn-radius, 0px);
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity .2s;
}

.lv-search .add-to-cart svg {
  width: 16px;
  height: 16px;
  flex-shrink: 0;
  pointer-events: none;
}

.lv-search .add-to-cart:hover {
  opacity: .82;
}

.lv-search .add-to-cart[disabled] {
  opacity: .45;
  cursor: not-allowed;
  background: #aaa;
}

.lv-search .add-to-cart.adding {
  opacity: .65;
  cursor: wait;
}

.lv-search .add-to-cart.added {
  background: var(--color-success, #2a7a2a) !important;
  color: #fff;
  opacity: 1;
  cursor: default;
}

/* Article / page result card */
.lv-search .lv-search-card {
  display: flex;
  flex-direction: column;
  height: 100%;
  text-decoration: none;
  border: 1px solid rgba(var(--color-foreground), 0.14);
  border-radius: var(--lv-card-radius, 6px);
  overflow: hidden;
  background: rgb(var(--color-background));
}

.lv-search .lv-search-card__media {
  aspect-ratio: 3/4;
  overflow: hidden;
  background: rgba(var(--color-foreground), 0.06);
}

.lv-search .lv-search-card__media img,
.lv-search .lv-search-card__media .placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform .35s ease;
}

.lv-search .lv-search-card:hover .lv-search-card__media img {
  transform: scale(1.04);
}

.lv-search .lv-search-card__body {
  padding: 14px;
  display: flex;
  flex-direction: column;
  gap: 6px;
  flex: 1;
}

.lv-search .lv-search-card__type {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: rgb(var(--color-foreground));
  opacity: .5;
}

.lv-search .lv-search-card__title {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.45;
  color: rgb(var(--color-foreground));
  margin: 0;
}

/* Pagination */
.lv-search .lv-search-pagination {
  text-align: center;
  margin-top: 48px;
}

.lv-search .lv-search-pagination a,
.lv-search .lv-search-pagination span {
  display: inline-block;
  padding: 8px 14px;
  margin: 0 3px;
  border: 1px solid rgba(var(--color-foreground), 0.18);
  color: rgb(var(--color-foreground));
  font-size: 14px;
  transition: background .2s, color .2s, border-color .2s;
}

.lv-search .lv-search-pagination a:hover,
.lv-search .lv-search-pagination .current {
  background: rgb(var(--color-button));
  color: rgb(var(--color-button-text));
  border-color: rgb(var(--color-button));
}

@media (max-width: 1024px) {
  .lv-search .lv-search-inner {
    padding: 0 32px;
  }

  .lv-search .lv-search-grid,
  .lv-search .lv-search-body--no-sidebar .lv-search-grid {
    grid-template-columns: repeat(var(--lv-search-cols-t, 3), minmax(0, 1fr));
  }
}

@media (max-width: 768px) {
  .lv-search .lv-search-inner {
    padding: 0 20px;
  }

  .lv-search .lv-search-body {
    display: block;
  }

  .lv-search .lv-search-sidebar {
    width: 100%;
    margin-bottom: 24px;
  }

  .lv-search .lv-search-grid,
  .lv-search .lv-search-body--no-sidebar .lv-search-grid {
    grid-template-columns: repeat(var(--lv-search-cols-m, 2), minmax(0, 1fr));
    gap: 20px 12px;
  }
}

@media (max-width: 480px) {
  .lv-search .lv-search-inner {
    padding: 0 16px;
  }

  .lv-search .lv-search-grid {
    gap: 16px 10px;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  function initSearch(root) {
    if (root.dataset.lvSearchInit) return;
    root.dataset.lvSearchInit = '1';

    var SID = root.dataset.lvSearchId;
    var searchTerms = root.dataset.searchTerms || '';

    var modal      = document.getElementById('lv-vm-search-' + SID);
    var modalTitle = document.getElementById('lv-vm-search-title-' + SID);
    var modalOpts  = document.getElementById('lv-vm-search-opts-' + SID);
    var modalAtc   = document.getElementById('lv-vm-search-atc-' + SID);
    var modalClose = document.getElementById('lv-vm-search-close-' + SID);
    var selectedVid = null;

    var L = {
      choose: (modalAtc && modalAtc.dataset.labelChoose) || 'Choose a size',
      addPrefix: (modalAtc && modalAtc.dataset.labelAddPrefix) || 'Add To Cart — ',
      adding: (modalAtc && modalAtc.dataset.labelAdding) || 'Adding…'
    };

    function toggleFilterGroup(btn) {
      var body = btn.parentElement.querySelector('.lv-filter-group__body');
      var arrow = btn.querySelector('.lv-fg-arrow');
      if (!body) return;
      body.classList.toggle('collapsed');
      if (arrow) arrow.innerHTML = body.classList.contains('collapsed') ? '+' : '&#8722;';
    }

    function serializeFilterForm(form) {
      var url = new URL(window.location.href);
      url.search = '';
      url.searchParams.set('q', searchTerms);

      var fd = new FormData(form);
      fd.forEach(function (value, key) {
        if (value !== '' && value !== null) {
          url.searchParams.append(key, value);
        }
      });

      window.location.href = url.toString();
    }

    function openModal(btn) {
      if (!modal) return;
      modalTitle.textContent = btn.dataset.productTitle || '';
      modalOpts.innerHTML = '';
      selectedVid = null;
      modalAtc.disabled = true;
      modalAtc.textContent = L.choose;

      (btn.dataset.variants || '').split('::').forEach(function (v) {
        if (!v) return;
        var p = v.split('||');
        var vid = p[0];
        var vtitle = p[1];
        var avail = p[2];
        if (!vid || !vtitle) return;

        var opt = document.createElement('button');
        opt.type = 'button';
        opt.className = 'lv-variant-modal__opt';
        opt.textContent = vtitle;
        if (avail === 'false') { opt.disabled = true; }

        opt.addEventListener('click', function () {
          if (opt.disabled) return;
          modalOpts.querySelectorAll('.lv-variant-modal__opt').forEach(function (o) { o.classList.remove('selected'); });
          opt.classList.add('selected');
          selectedVid = vid;
          modalAtc.disabled = false;
          modalAtc.textContent = L.addPrefix + vtitle;
        });

        modalOpts.appendChild(opt);
      });

      modal.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      if (!modal) return;
      modal.classList.remove('open');
      document.body.style.overflow = '';
      selectedVid = null;
    }

    function doATC(vid, btn, origHTML) {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify({ id: parseInt(vid, 10), quantity: 1 })
      })
      .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
      .then(function () {
        if (btn) {
          btn.classList.remove('adding');
          btn.classList.add('added');
          btn.innerHTML = 'Added &#10003;';
          setTimeout(function () { if (btn) { btn.innerHTML = origHTML; btn.classList.remove('added'); } }, 2000);
        }
        document.dispatchEvent(new CustomEvent('cart:updated', { bubbles: true, detail: { variantId: vid } }));
        document.dispatchEvent(new CustomEvent('cart:open'));
        closeModal();
      })
      .catch(function (err) {
        console.warn('[Search ATC]', err);
        if (btn) { btn.classList.remove('adding'); btn.innerHTML = origHTML; }
        closeModal();
      });
    }

    root.querySelectorAll('.lv-filters-form').forEach(function (form) {
      form.addEventListener('change', function (e) {
        if (e.target.matches('input[type="checkbox"]')) {
          serializeFilterForm(form);
        }
      });
      form.addEventListener('submit', function (e) {
        e.preventDefault();
        serializeFilterForm(form);
      });
    });

    if (modalClose) modalClose.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', function (e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal && modal.classList.contains('open')) closeModal();
    });

    if (modalAtc) modalAtc.addEventListener('click', function () {
      if (!selectedVid) return;
      var original = modalAtc.textContent;
      modalAtc.disabled = true;
      modalAtc.textContent = L.adding;
      doATC(selectedVid, null, original);
    });

    root.addEventListener('click', function (e) {
      var filterToggle = e.target.closest('.lv-filter-group__toggle');
      if (filterToggle) {
        e.preventDefault();
        toggleFilterGroup(filterToggle);
        return;
      }

      var btn = e.target.closest('.add-to-cart');
      if (!btn || btn.disabled || btn.getAttribute('aria-disabled') === 'true') return;
      if (btn.classList.contains('adding') || btn.classList.contains('added')) return;

      var vid = btn.dataset.variantId;
      var isMulti = btn.dataset.multi === 'true';

      if (isMulti) { openModal(btn); return; }
      if (!vid || vid === '' || vid === 'undefined') { window.location.href = btn.dataset.productUrl || '/'; return; }

      var origHTML = btn.innerHTML;
      btn.classList.add('adding');
      btn.innerHTML = 'Adding…';
      doATC(vid, btn, origHTML);
    });
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('.lv-search').forEach(initSearch);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  document.addEventListener('shopify:section:load', function (e) {
    initAll(e.target);
  });
})();
{% endjavascript %}

