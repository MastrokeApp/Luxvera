{{ 'lv-currency.css' | asset_url | stylesheet_tag }}
{{ 'lv-header.css' | asset_url | stylesheet_tag }}

<script src="{{ 'lv-currency.js' | asset_url }}" defer></script>
<script src="{{ 'lv-header.js' | asset_url }}" defer></script>

<div class="lv-header-wrap{% if section.settings.sticky %} lv-header-wrap--sticky{% endif %}">

  {%- if section.settings.show_top_bar -%}
  <div class="lv-top-bar color-{{ section.settings.top_bar_color_scheme }}">
    <div class="lv-top-bar__inner">
   
      {% render 'currency-switcher', position: 'topbar' %}
      <!-- Centre -->
      <span>{{ section.settings.top_bar_center | default: 'Welcome to our Store' }}</span>
      <!-- Right -->
      {% if section.settings.top_bar_link_url != blank %}
  <a href="{{ section.settings.top_bar_link_url }}">
    {{ section.settings.top_bar_right | default: 'Sign In / Register' }}
  </a>
{% endif %}
    </div>
  </div>
  {%- endif -%}

  <!-- HEADER -->
  <header
    class="lv-header color-{{ section.settings.header_color_scheme }}"
    id="lv-header-{{ section.id }}"
    style="--lv-hdr-height:{{ section.settings.header_height }}px;"
  >
    <nav class="lv-nav" aria-label="{{ 'accessibility.main_navigation' | t }}">
      <div class="lv-nav__left">
        <button class="lv-hamburger" id="lvHamburger" aria-label="{{ 'accessibility.open_menu' | t }}" aria-expanded="false" aria-controls="lvMobileMenu"><span></span><span></span><span></span></button>
        <div class="lv-nav__links">
         {%- for link in linklists[section.settings.menu].links -%}
  {%- if link.links.size > 0 -%}

    {%- assign is_mega = false -%}

    {%- if section.settings.enable_mega_menu -%}
      {%- assign is_mega = true -%}
    {%- endif -%}

    <div class="lv-nav__item" data-lv-dropdown>
      <button
        class="lv-nav__link"
        aria-haspopup="true"
        aria-expanded="false"
      >
        {{ link.title }}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>

      {%- if is_mega -%}
        {% render 'lv-menu-mega', link: link %}
      {%- else -%}
        {% render 'lv-menu-dropdown', link: link %}
      {%- endif -%}
    </div>

  {%- else -%}

    <div class="lv-nav__item">
      <a class="lv-nav__link" href="{{ link.url }}">{{ link.title }}</a>
    </div>

  {%- endif -%}
{%- endfor -%}
        </div>
      </div>

      <a href="{{ routes.root_url }}" class="lv-logo" aria-label="{{ shop.name }} home">
        {%- if settings.logo != blank -%}
          {%- assign logo_height = 160 | divided_by: settings.logo.aspect_ratio | round -%}
          <img src="{{ settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}" width="160" height="{{ logo_height }}" loading="eager">
        {%- else -%}
          <span class="lv-logo__name">{{ section.settings.brand_name | default: shop.name | upcase }}</span>
          <div class="lv-logo__sub-row"><span class="lv-logo__line"></span><span class="lv-logo__sub">{{ section.settings.brand_tagline | default: 'Fashion' }}</span><span class="lv-logo__line"></span></div>
        {%- endif -%}
      </a>

      <div class="lv-nav__right">
        <button class="lv-icon-btn" id="lvSearchBtn" aria-label="{{ 'accessibility.search' | t }}">
           {{ 'icon-search.svg' | inline_asset_content }} </button>
        <a href="{{ routes.account_url }}" class="lv-icon-btn" aria-label="{{ 'accessibility.account' | t }}">
          {{ 'icon-account.svg' | inline_asset_content }}</a>

{% if settings.cart_type == 'page' %}

  <a href="{{ routes.cart_url }}"
     class="lv-icon-btn lv-icon-btn--cart"
     aria-label="{{ 'accessibility.cart' | t }}">

      {% if cart == empty %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}

    {% if cart.item_count > 0 %}
      <span class="lv-cart-badge">{{ cart.item_count }}</span>
    {% endif %}

  </a>

{% else %}

  <button
    type="button"
    class="lv-icon-btn lv-icon-btn--cart js-cart-drawer-open"
    aria-label="{{ 'accessibility.cart' | t }}">

      {% if cart == empty %}
           <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% else %}
          <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
        {% endif %}

    {% if cart.item_count > 0 %}
      <span class="lv-cart-badge">{{ cart.item_count }}</span>
    {% endif %}

  </button>

{% endif %}
      </div>
    </nav>
  </header>
</div>

<!-- MOBILE DRAWER -->
<div class="lv-mobile-menu" id="lvMobileMenu" aria-hidden="true">
  <div class="lv-mobile-drawer color-{{ section.settings.header_color_scheme }}">
    <div class="lv-drawer-head">
      <span class="lv-drawer-logo">{{ section.settings.brand_name | default: shop.name | upcase }}</span>
      <button class="lv-drawer-close" id="lvDrawerClose" aria-label="{{ 'accessibility.close_menu' | t }}">✕</button>
    </div>
    <nav class="lv-drawer-nav">
      {%- for link in linklists[section.settings.menu].links -%}
        <div class="lv-drawer-item">
          {%- if link.links.size > 0 -%}
            <button class="lv-drawer-link" data-lv-drawer-toggle aria-expanded="false">{{ link.title }}<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="6 9 12 15 18 9"/></svg></button>
            <div class="lv-drawer-sub">{%- for child in link.links -%}<a href="{{ child.url }}">{{ child.title }}</a>{%- endfor -%}</div>
          {%- else -%}
            <a class="lv-drawer-link" href="{{ link.url }}">{{ link.title }}</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </nav>
    <div class="lv-drawer-footer">
      {% render 'currency-switcher', position: 'mobile' %}
      <a href="{{ routes.account_url }}"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>{{ 'header.my_account' | t }}</a>
    </div>
  </div>
</div>

<!-- SEARCH OVERLAY -->
<div class="lv-search-overlay" id="lvSearchOverlay" role="dialog" aria-modal="true" aria-label="{{ 'accessibility.search' | t }}">
  <div class="lv-search-box color-{{ section.settings.header_color_scheme }}">
    <form action="{{ routes.search_url }}" method="get" role="search">
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder | default: 'Search products, styles, collections…' }}" id="lvSearchInput" autocomplete="off" aria-label="{{ 'accessibility.search' | t }}">
    </form>
    <button class="lv-search-close" id="lvSearchClose" aria-label="{{ 'accessibility.close_search' | t }}">✕</button>
  </div>
</div>



{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "header",
      "content": "t:labels.top_bar"
    },
    {
      "type": "checkbox",
      "id": "show_top_bar",
      "label": "t:labels.show_top_bar",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "top_bar_color_scheme",
      "label": "t:labels.top_bar_color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "top_bar_center",
      "label": "t:labels.centre_text",
      "default": "Welcome to Our Store"
    },
    {
      "type": "text",
      "id": "top_bar_right",
      "label": "t:labels.right_link_text",
      "default": "Sign In / Register"
    },
    {
      "type": "url",
      "id": "top_bar_link_url",
      "label": "t:labels.right_link_url"
    },
    {
      "type": "header",
      "content": "t:labels.header"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "t:labels.brand_name",
      "default": "LUXVERA"
    },
    {
      "type": "text",
      "id": "brand_tagline",
      "label": "t:labels.brand_tagline",
      "default": "Fashion"
    },
    {
      "type": "color_scheme",
      "id": "header_color_scheme",
      "label": "t:labels.header_color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "header_height",
      "label": "t:labels.header_height",
      "min": 56,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "t:labels.sticky_header",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_mega_menu",
      "label": "t:labels.enable_mega_menu",
      "default": false
    },
    {
      "type": "header",
      "content": "t:labels.navigation"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "mega_col1_label",
      "label": "t:labels.mega_menu_col_1_heading",
      "default": "By Style"
    },
    {
      "type": "text",
      "id": "mega_col2_label",
      "label": "t:labels.mega_menu_col_2_heading",
      "default": "By Category"
    },
    {
      "type": "header",
      "content": "t:labels.search"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "t:labels.search_placeholder",
      "default": "Search products, styles, collections…"
    }
  ],
  "presets": [
    {
      "name": "t:general.header"
    }
  ]
}
{% endschema %}