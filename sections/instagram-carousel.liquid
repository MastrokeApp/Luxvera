    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "t:labels.autoplay_delay_seconds",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "t:general.instagram_post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "t:labels.alt_text",
