{% comment %}
  Section: Brand Story

  Two-column brand intro: copy + selectable tabs on the left that swap
  layered images on the right. Colours come from Theme Settings → Colors.
{% endcomment %}

<section
  class="brand-section"
  id="brand-story-{{ section.id }}"
  style="
    --bs-pt: {{ section.settings.padding_top | default: 72 }}px;
    --bs-pb: {{ section.settings.padding_bottom | default: 72 }}px;
    --bs-pt-m: {{ section.settings.padding_top | default: 0 | times: 0.6 | round }}px;
    --bs-pb-m: {{ section.settings.padding_bottom | default: 0 | times: 0.6 | round }}px;
  "
>
  <div class="brand-inner">
    <div class="brand-left">
      <div class="brand-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.34 2.23l.58 3.57a1 1 0 00.99.84H6v10c0 1.1.9 2 2 2h8a2 2 0 002-2V10h2.15a1 1 0 00.99-.84l.58-3.57a2 2 0 00-1.34-2.23z"/></svg></div>
      <div>
        <div class="brand-logo-name">{{ section.settings.brand_name | default: 'LUXVERA' | escape }}</div>
        <div class="logo-sub-row"><span class="logo-line"></span><span class="logo-sub">{{ section.settings.brand_tagline | default: 'Fashion' | escape }}</span><span class="logo-line"></span></div>
      </div>
      {%- if section.settings.heading != blank -%}<h3>{{ section.settings.heading | escape }}</h3>{%- endif -%}
      {%- if section.settings.body_text != blank -%}<p>{{ section.settings.body_text | escape }}</p>{%- endif -%}
      {%- if section.settings.explore_label != blank -%}<span class="brand-label">{{ section.settings.explore_label | escape }}</span>{%- endif -%}
      <div class="brand-links">
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand_tab' -%}
            <div
              class="brand-link-row{% if forloop.first %} active{% endif %}"
              data-lv-brand-tab="{{ section.id }}-{{ forloop.index0 }}"
              role="button"
              tabindex="0"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              {{ block.shopify_attributes }}
            >
              <span>{{ block.settings.label | default: 'Collection' | escape }}</span>
              <span class="bl-chevron" aria-hidden="true">›</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_url | default: '/collections/all' }}" class="btn-outline" {% if section.settings.cta_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>{{ section.settings.cta_label | escape }} →</a>
      {%- endif -%}
    </div>
    <div class="brand-right">
      {%- for block in section.blocks -%}
        {%- if block.type == 'brand_tab' -%}
          <div class="brand-img-panel{% if forloop.first %} active{% endif %}" data-lv-brand-panel="{{ section.id }}-{{ forloop.index0 }}">
            <div class="brand-img-back">{%- if block.settings.image_back != blank -%}<img src="{{ block.settings.image_back | image_url: width: 500, height: 700, crop: 'center' }}" alt="" width="500" height="700" loading="lazy">{%- else -%}{{ 'collection-1' | placeholder_svg_tag: 'brand-placeholder' }}{%- endif -%}</div>
            <div class="brand-img-front">{%- if block.settings.image_front != blank -%}<img src="{{ block.settings.image_front | image_url: width: 600, height: 800, crop: 'center' }}" alt="{{ block.settings.label | escape }}" width="600" height="800" loading="lazy">{%- else -%}{{ 'collection-2' | placeholder_svg_tag: 'brand-placeholder' }}{%- endif -%}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
.brand-section {
  background: var(--lv-color-bg, #ffffff);
  overflow: hidden;
  width: 100%;
}

.brand-section .brand-inner {
  max-width: var(--lv-container-max, 1280px);
  margin: 0 auto;
  padding: var(--bs-pt, 72px) 56px var(--bs-pb, 72px);
  display: grid;
  grid-template-columns: 340px 1fr;
  gap: 80px;
  align-items: center;
  box-sizing: border-box;
}

.brand-section .brand-icon {
  width: 48px;
  height: 48px;
  background: var(--lv-color-bg-alt, #f7f4f0);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
  color: var(--lv-color-text, #1a1a1a);
  opacity: 0.5;
}

.brand-section .brand-icon svg {
  width: 24px;
  height: 24px;
}

.brand-section .brand-logo-name {
  font-size: 17px;
  font-weight: 800;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--lv-color-text, #1a1a1a);
}

.brand-section .logo-sub-row {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-top: 3px;
}

.brand-section .logo-line {
  height: 1px;
  background: var(--lv-color-text, #1a1a1a);
  width: 20px;
  opacity: 0.4;
}

.brand-section .logo-sub {
  font-size: 8px;
  font-weight: 500;
  letter-spacing: .32em;
  text-transform: uppercase;
  color: var(--lv-color-text, #1a1a1a);
  opacity: 0.6;
  white-space: nowrap;
}

.brand-section .brand-left h3 {
  font-size: 26px;
  font-weight: 700;
  margin: 22px 0 12px;
  line-height: 1.3;
  color: var(--lv-color-text, #1a1a1a);
}

.brand-section .brand-left > p {
  font-size: 13px;
  color: var(--lv-color-text, #1a1a1a);
  opacity: 0.6;
  line-height: 1.9;
  margin-bottom: 28px;
}

.brand-section .brand-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--lv-color-text, #1a1a1a);
  margin-bottom: 6px;
  display: block;
}

.brand-section .brand-links {
  margin-bottom: 28px;
  border-top: 1px solid var(--lv-color-border, #e5e0d8);
}

.brand-section .brand-link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1px solid var(--lv-color-border, #e5e0d8);
  padding: 13px 4px 13px 12px;
  font-size: 13px;
  font-weight: 500;
  color: var(--lv-color-text, #1a1a1a);
  opacity: 0.7;
  cursor: pointer;
  transition: color .2s, opacity .2s;
  border-radius: 4px;
  position: relative;
  width: 100%;
  background: none;
  text-align: left;
}

.brand-section .bl-chevron {
  font-size: 16px;
  transition: color .2s, transform .2s;
}

.brand-section .brand-link-row:hover {
  opacity: 1;
}

.brand-section .brand-link-row:focus-visible {
  outline: 2px solid var(--lv-color-primary, #2a1f16);
  outline-offset: 2px;
  opacity: 1;
}

.brand-section .brand-link-row.active {
  opacity: 1;
  font-weight: 700;
  background: var(--lv-color-bg-alt, #f7f4f0);
}

.brand-section .brand-link-row.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 22px;
  background: var(--lv-color-primary, #2a1f16);
  border-radius: 0 2px 2px 0;
}

.brand-section .btn-outline {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  color: var(--lv-color-primary, #2a1f16);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  padding: 11px 24px;
  border: 1.5px solid var(--lv-color-primary, #2a1f16);
  text-decoration: none;
  transition: background .25s, color .25s;
  border-radius: var(--lv-btn-radius, 0px);
}

.brand-section .btn-outline:hover {
  background: var(--lv-color-primary, #2a1f16);
  color: #ffffff;
}

/* ─ RIGHT IMAGE AREA ─ */
.brand-section .brand-right {
  position: relative;
  height: 500px;
  overflow: hidden;
}

.brand-section .brand-img-panel {
  position: absolute;
  inset: 0;
  opacity: 0;
  pointer-events: none;
  transition: opacity .45s ease;
}

.brand-section .brand-img-panel.active {
  opacity: 1;
  pointer-events: auto;
}

.brand-section .brand-img-back {
  position: absolute;
  left: 0;
  top: 40px;
  width: 48%;
  height: 420px;
  border-radius: 10px;
  overflow: hidden;
  z-index: 1;
}

.brand-section .brand-img-back img,
.brand-section .brand-img-back svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.brand-section .brand-img-front {
  position: absolute;
  right: 0;
  top: 0;
  width: 60%;
  height: 500px;
  border-radius: 10px;
  overflow: hidden;
  z-index: 2;
  box-shadow: -6px 6px 24px rgba(0,0,0,.10);
}

.brand-section .brand-img-front img,
.brand-section .brand-img-front svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ─ TABLET ─ */
@media (max-width: 1024px) {
  .brand-section .brand-inner {
    grid-template-columns: 1fr;
    gap: 40px;
    padding-left: 32px;
    padding-right: 32px;
  }

  .brand-section .brand-right {
    height: 380px;
  }

  .brand-section .brand-img-back {
    height: 320px;
    top: 30px;
  }

  .brand-section .brand-img-front {
    height: 380px;
  }
}

/* ─ MOBILE ─ */
@media (max-width: 768px) {
  .brand-section .brand-inner {
    padding: var(--bs-pt-m, 43px) 20px var(--bs-pb-m, 43px);
    gap: 32px;
  }

  /* On mobile switch from absolute positioning to normal flow with a single image */
  .brand-section .brand-right {
    position: relative;
    height: 260px;
    overflow: hidden;
    border-radius: 10px;
  }

  .brand-section .brand-img-panel {
    position: absolute;
    inset: 0;
  }

  /* On mobile show only the front image, full width */
  .brand-section .brand-img-back {
    display: none;
  }

  .brand-section .brand-img-front {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    box-shadow: none;
  }
}

@media (max-width: 480px) {
  .brand-section .brand-inner {
    padding-left: 16px;
    padding-right: 16px;
  }

  .brand-section .brand-right {
    height: 220px;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  'use strict';

  function activate(root, tab, tabs, panels) {
    var key = tab.getAttribute('data-lv-brand-tab');

    tabs.forEach(function (t) {
      t.classList.remove('active');
      t.setAttribute('aria-pressed', 'false');
    });
    tab.classList.add('active');
    tab.setAttribute('aria-pressed', 'true');

    panels.forEach(function (p) { p.classList.remove('active'); });
    var target = root.querySelector('[data-lv-brand-panel="' + key + '"]');
    if (target) target.classList.add('active');
  }

  function initBrandStory(root) {
    if (root.dataset.lvBrandInit) return;
    root.dataset.lvBrandInit = '1';

    var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-lv-brand-tab]'));
    var panels = Array.prototype.slice.call(root.querySelectorAll('[data-lv-brand-panel]'));
    if (!tabs.length) return;

    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(root, tab, tabs, panels);
      });
      tab.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ' || e.key === 'Spacebar') {
          e.preventDefault();
          activate(root, tab, tabs, panels);
        }
      });
    });
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('.brand-section').forEach(initBrandStory);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  document.addEventListener('shopify:section:load', function (e) {
    initAll(e.target);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "luxvera-brand-story",
  "settings": [
    { "type": "header", "content": "Section Padding" },
    { "type": "range", "id": "padding_top",    "label": "Padding Top",    "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 72 },
    { "type": "header", "content": "Brand Identity", "info": "Colors are controlled by Theme Settings → Colors" },
    { "type": "text", "id": "brand_name",    "label": "Brand Name",    "default": "LUXVERA" },
    { "type": "text", "id": "brand_tagline", "label": "Brand Tagline", "default": "Fashion" },
    { "type": "header", "content": "Content" },
    { "type": "text",     "id": "heading",       "label": "Heading",       "default": "More Than Style" },
    { "type": "textarea","id": "body_text",      "label": "Body Text",     "default": "This is more than a boutique, it's a space where confidence feels natural and being yourself is enough." },
    { "type": "text",    "id": "explore_label", "label": "Explore Label", "default": "Explore" },
    { "type": "header", "content": "CTA Button" },
    { "type": "text",     "id": "cta_label",   "label": "Button Label",    "default": "Explore Collections" },
    { "type": "url",      "id": "cta_url",     "label": "Button URL" },
    { "type": "checkbox", "id": "cta_new_tab", "label": "Open in new tab", "default": false }
  ],
  "blocks": [{
    "type": "brand_tab", "name": "Brand Tab",
    "settings": [
      { "type": "text",         "id": "label",       "label": "Tab Label",        "default": "Best Sellers" },
      { "type": "image_picker", "id": "image_back",  "label": "Background Image", "info": "500×700px recommended" },
      { "type": "image_picker", "id": "image_front", "label": "Foreground Image", "info": "600×800px recommended" }
    ]
  }],
  "presets": [{"name":"Brand Story","category":"Brand","blocks":[{"type":"brand_tab","settings":{"label":"Best Sellers"}},{"type":"brand_tab","settings":{"label":"New Season Edit"}},{"type":"brand_tab","settings":{"label":"Vacation Looks"}},{"type":"brand_tab","settings":{"label":"Winter Luxe"}}]}]
}
{% endschema %}
