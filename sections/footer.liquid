{{ 'lv-footer.css' | asset_url | stylesheet_tag }}

{%- assign nl_form_id = 'FooterNewsletterForm-' | append: section.id -%}

<div
  id="lv-footer-{{ section.id }}"
  class="lv-footer color-{{ section.settings.color_scheme }}{% if section.settings.enable_accordion %} lv-footer--accordion{% endif %}"
  style="
    --footer-body-size: {{ section.settings.body_font_size | default: 13 }}px;
    --footer-heading-size: {{ section.settings.col_heading_size | default: 12 }}px;
  "
  data-accordion-enabled="{{ section.settings.enable_accordion }}"
>
  <div class="lv-footer-grid">

    {% for block in section.blocks %}
      {% if block.settings.enable_block %}
        {% case block.type %}

          {% when 'brand' %}
            <div class="lv-footer-brand" {{ block.shopify_attributes }}>
              <div>
                {% if block.settings.logo != blank %}
                  {%- assign lv_footer_logo_height = 160 | divided_by: block.settings.logo.aspect_ratio | round -%}
                  <a href="{{ routes.root_url }}" class="lv-footer-brand-link">
                    <img
                      src="{{ block.settings.logo | image_url: width: 160 }}"
                      alt="{{ shop.name }}"
                      class="lv-footer-logo"
                      width="160"
                      height="{{ lv_footer_logo_height }}"
                      loading="lazy"
                    >
                  </a>
                {% else %}
                  <div class="lv-footer-brand-name">
                    <a href="{{ routes.root_url }}" class="lv-footer-brand-link">
                      {{ block.settings.brand_name | default: shop.name | upcase }}
                      <div class="lv-logo__sub-row"><span class="lv-logo__line"></span><span class="lv-logo__sub">{{ section.settings.brand_sub | default: 'Fashion' }}</span><span class="lv-logo__line"></span></div>
                    </a>
                  </div>
                {% endif %}
              </div>

              {% if block.settings.brand_description != blank %}
                <p>{{ block.settings.brand_description }}</p>
              {% endif %}

              {% if section.settings.show_social_icons %}
                <div class="lv-footer-social-row">
                  {% render 'social-media-link' %}
                </div>
              {% endif %}
            </div>

          {% when 'menu' %}
            {%- assign lv_col_id = 'lv-footer-col-' | append: block.id -%}
            {%- assign lv_col_accordion = false -%}
            {%- if section.settings.enable_accordion and block.settings.enable_accordion -%}
              {%- assign lv_col_accordion = true -%}
            {%- endif -%}
            <div class="lv-footer-col{% if lv_col_accordion %} lv-accordion-item{% endif %}">
              {% if block.settings.heading != blank %}
                {% if lv_col_accordion %}
                  <h5>
                    <button
                      type="button"
                      class="lv-accordion-trigger"
                      aria-expanded="false"
                      aria-controls="{{ lv_col_id }}"
                    >
                      <span>{{ block.settings.heading }}</span>
                      <span class="lv-accordion-icon" aria-hidden="true"></span>
                    </button>
                  </h5>
                {% else %}
                  <h5>{{ block.settings.heading }}</h5>
                {% endif %}
              {% endif %}

              {% if block.settings.menu != blank %}
                <ul
                  id="{{ lv_col_id }}"
                  class="lv-accordion-panel"
                  {% if lv_col_accordion %}hidden{% endif %}
                >
                  {% for link in block.settings.menu.links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                </ul>
              {% endif %}
            </div>

          {% when 'newsletter' %}
            {%- assign lv_nl_id = 'lv-footer-col-' | append: block.id -%}
            {%- assign lv_nl_accordion = false -%}
            {%- if section.settings.enable_accordion and block.settings.enable_accordion -%}
              {%- assign lv_nl_accordion = true -%}
            {%- endif -%}
            <div class="lv-footer-col{% if lv_nl_accordion %} lv-accordion-item{% endif %}">
              {% if block.settings.heading != blank %}
                {% if lv_nl_accordion %}
                  <h5>
                    <button
                      type="button"
                      class="lv-accordion-trigger"
                      aria-expanded="false"
                      aria-controls="{{ lv_nl_id }}"
                    >
                      <span>{{ block.settings.heading }}</span>
                      <span class="lv-accordion-icon" aria-hidden="true"></span>
                    </button>
                  </h5>
                {% else %}
                  <h5>{{ block.settings.heading }}</h5>
                {% endif %}
              {% endif %}

              <div
                id="{{ lv_nl_id }}"
                class="lv-accordion-panel"
                {% if lv_nl_accordion %}hidden{% endif %}
              >
                {% form 'customer', id: nl_form_id %}
                  {% if form.posted_successfully? %}
                    <p class="newsletter-success">{{ block.settings.thankyou_msg }}</p>
                  {% endif %}

                  {% if form.errors %}
                    <div class="newsletter-error">{{ form.errors | default_errors }}</div>
                  {% endif %}

                  <input type="hidden" name="contact[tags]" value="newsletter">

                  <div class="lv-newsletter-form">
                    <input
                      type="email"
                      name="contact[email]"
                      placeholder="{{ section.settings.newsletter_placeholder }}"
                      required
                    >
                    <button type="submit" aria-label="{{ 'accessibility.subscribe' | t }}">
                      {{ 'icon-subscribe.svg' | inline_asset_content }}
                    </button>
                  </div>

                  <label class="lv-newsletter-consent">
                    <input type="checkbox" required>
                    <span>{{ block.settings.newsletter_consent }}</span>
                  </label>
                {% endform %}
              </div>
            </div>

        {% endcase %}
      {% endif %}
    {% endfor %}

  </div>

  <div class="lv-footer-bottom">
    <p>
      &copy; {{ 'now' | date: '%Y' }}
      {% assign footer_brand_name = shop.name %}
      {% for block in section.blocks %}
        {% if block.type == 'brand' and block.settings.brand_name != blank %}
          {% assign footer_brand_name = block.settings.brand_name %}
          {% break %}
        {% endif %}
      {% endfor %}
      {{ footer_brand_name }} {{ section.settings.bottom_tagline | default: 'Fashion. All rights reserved.' }}
    </p>

    <div class="lv-footer-bottom-right">
      {%- if section.settings.show_currency_switcher -%}
        {% render 'currency-switcher', position: 'footer' %}
      {%- endif -%}

      {%- if section.settings.show_payment_icons -%}
        {%- comment -%} Use the store's actually-enabled payment providers; fall back to a default set. {%- endcomment -%}
        {%- assign pay_types = shop.enabled_payment_types -%}
        {%- if pay_types.size == 0 -%}
          {%- assign pay_types = 'visa,master,american_express,apple_pay,google_pay,shopify_pay' | split: ',' -%}
        {%- endif -%}
        <ul class="lv-pay-icons" role="list" aria-label="{{ 'accessibility.accepted_payment_methods' | t }}">
          {%- for type in pay_types -%}
            <li class="lv-pay-icon">{{ type | payment_type_svg_tag: class: 'lv-pay-svg' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% javascript %}
(function () {
  'use strict';

  function initFooterAccordion(root) {
    if (root.dataset.lvFooterAccordionInit) return;
    root.dataset.lvFooterAccordionInit = '1';

    root.addEventListener('click', function (e) {
      var trigger = e.target.closest('.lv-accordion-trigger');
      if (!trigger || !root.contains(trigger)) return;

      var panelId = trigger.getAttribute('aria-controls');
      var panel = panelId && document.getElementById(panelId);
      if (!panel) return;

      var isOpen = trigger.getAttribute('aria-expanded') === 'true';
      trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      if (isOpen) {
        panel.setAttribute('hidden', '');
      } else {
        panel.removeAttribute('hidden');
      }
    });
  }

  function initAll(scope) {
    (scope || document).querySelectorAll('.lv-footer').forEach(initFooterAccordion);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function () { initAll(); });
  } else {
    initAll();
  }

  document.addEventListener('shopify:section:load', function (e) {
    initAll(e.target);
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "header",
      "content": "t:labels.layout"
    },
    {
      "type": "checkbox",
      "id": "enable_accordion",
      "label": "t:labels.enable_accordion_for_footer_columns",
      "info": "t:labels.collapses_menu_and_newsletter_columns_into",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-3"
    },
    {
      "type": "text",
      "id": "brand_sub",
      "label": "t:labels.brand_sub_label",
      "default": "Fashion"
    },
    {
      "type": "text",
      "id": "bottom_tagline",
      "label": "t:labels.bottom_tagline",
      "default": "Fashion. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_social_icons",
      "label": "t:labels.show_social_icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_currency_switcher",
      "label": "t:labels.show_currency_switcher",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "t:labels.newsletter_email_placeholder",
      "default": "Enter your email"
    },
    {
      "type": "range",
      "id": "body_font_size",
      "label": "t:labels.body_font_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "col_heading_size",
      "label": "t:labels.column_heading_size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:general.brand",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_block",
          "label": "t:labels.enable",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "logo",
          "label": "t:labels.logo"
        },
        {
          "type": "text",
          "id": "brand_name",
          "label": "t:labels.brand_name_2"
        },
        {
          "type": "textarea",
          "id": "brand_description",
          "label": "t:labels.description"
        }
      ]
    },
    {
      "type": "menu",
      "name": "t:general.menu",
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_block",
          "label": "t:labels.enable",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "enable_accordion",
          "label": "t:labels.enable_accordion",
          "default": true
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:labels.menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:general.newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "enable_block",
          "label": "t:labels.enable",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "enable_accordion",
          "label": "t:labels.enable_accordion",
          "default": true
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "text",
          "id": "thankyou_msg",
          "label": "t:labels.thank_you_message",
          "default": "Thanks for subscribing!"
        },
        {
          "type": "text",
          "id": "newsletter_consent",
          "label": "t:labels.consent_text",
          "default": "I agree to receive marketing emails."
        }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "t:general.footer",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "menu"
        },
        {
          "type": "menu"
        },
        {
          "type": "newsletter"
        }
      ]
    }
  ]
}
{% endschema %}
