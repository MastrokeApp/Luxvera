{% comment %}
  Section: Main Reset Password

  Reached via the password-reset link sent by email; lets the customer
  set a new password once. Shopify supplies `email` as the address the
  reset link was sent to.
{% endcomment %}

{{ 'lv-account.css' | asset_url | stylesheet_tag }}

<div class="lv-acct color-{{ section.settings.color_scheme }}" id="lv-reset-password-{{ section.id }}">
  <div class="lv-acct-wrap lv-acct-wrap--narrow">
    <h1 class="lv-acct-title">{{ 'customers.reset_password.title' | t }}</h1>
    {% comment %} theme-check-disable UndefinedObject {% endcomment %}
    <p class="lv-acct-lede">{{ 'customers.reset_password.subtext' | t: email: email }}</p>

    {%- form 'reset_customer_password', class: 'lv-acct-form' -%}
      {%- if form.errors -%}
        <div class="lv-acct-error">{{ form.errors | default_errors }}</div>
      {%- endif -%}

      <div class="lv-acct-field">
        <label for="lv-reset-password-{{ section.id }}-input">{{ 'customers.reset_password.password' | t }}</label>
        <input type="password" id="lv-reset-password-{{ section.id }}-input" name="customer[password]" autocomplete="new-password" required>
      </div>

      <div class="lv-acct-field">
        <label for="lv-reset-password-confirm-{{ section.id }}">{{ 'customers.reset_password.password_confirm' | t }}</label>
        <input type="password" id="lv-reset-password-confirm-{{ section.id }}" name="customer[password_confirmation]" autocomplete="new-password" required>
      </div>

      <button type="submit" class="lv-acct-submit">{{ 'customers.reset_password.submit' | t }}</button>
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "t:general.reset_password",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
